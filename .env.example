# ----------------------------------------------------------
#  Frontend environment (Vite — variables must start with VITE_)
# ----------------------------------------------------------

# API base URL.
# In development, leave this as /api/v1 and let Vite proxy it to the
# backend (configured in vite.config.js → server.proxy).
# In production, set it to your deployed API, e.g. https://api.yourdomain.com/api/v1
VITE_API_URL=/api/v1

# Google OAuth client ID ("Sign in with Google").
# Optional — if empty, the Google button is hidden and email/password login
# still works. Must be the SAME client ID configured on the backend.
VITE_GOOGLE_CLIENT_ID=

# Razorpay publishable key_id (OPTIONAL).
# The backend already returns key_id in the create-order response, so this is
# usually left blank. NEVER put the Razorpay key_secret in the frontend.
VITE_RAZORPAY_KEY_ID=
